// Prisma Schema for Voyager Travel Planner
// Database: PostgreSQL (Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  trips      Trip[]
  tripShares TripShare[] @relation("TripShareOwner")

  @@map("users")
}

model Trip {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  title       String
  destination String
  startDate   DateTime   @map("start_date") @db.Date
  endDate     DateTime   @map("end_date") @db.Date
  description String?
  budget      Decimal?   @db.Decimal(12, 2)
  currency    String     @default("TWD")
  status      TripStatus @default(PLANNING)
  coverImage  String?    @map("cover_image")
  shareToken  String?    @unique @map("share_token")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities Activity[]
  notes      Note[]
  shares     TripShare[]

  @@index([userId])
  @@map("trips")
}

model Activity {
  id        String           @id @default(uuid())
  tripId    String           @map("trip_id")
  day       Int
  date      DateTime?        @db.Date
  title     String
  category  ActivityCategory
  time      String?          // HH:MM format
  duration  Int?             // minutes
  location  String?
  address   String?
  lat       Decimal?         @db.Decimal(10, 7)
  lng       Decimal?         @db.Decimal(10, 7)
  cost      Decimal?         @db.Decimal(10, 2)
  notes     String?
  images    String[]         @default([])
  sortOrder Int              @default(0) @map("sort_order")
  isBackup  Boolean          @default(false) @map("is_backup")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([tripId, day])
  @@map("activities")
}

model TripShare {
  id         String   @id @default(uuid())
  tripId     String   @map("trip_id")
  ownerId    String   @map("owner_id")
  sharedWith String   @map("shared_with") // email of recipient
  createdAt  DateTime @default(now()) @map("created_at")

  trip  Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  owner User @relation("TripShareOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([tripId, sharedWith])
  @@index([sharedWith])
  @@map("trip_shares")
}

model Note {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  title     String
  content   String?  @map("description")
  sourceUrl String?  @map("source_url")
  images    String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("notes")
}

enum TripStatus {
  PLANNING
  ONGOING
  COMPLETED

  @@map("trip_status")
}

enum ActivityCategory {
  ATTRACTION
  RESTAURANT
  HOTEL
  TRANSPORT
  OTHER

  @@map("activity_category")
}
